{
  "name": "lti-toolkit",
  "version": "1.0.0",
  "type": "module",
  "description": "LTI Toolkit for ALT+CS Web Applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/alt-cs-lab/lti-toolkit"
  },
  "main": "index.js",
  "scripts": {
    "lint": "npx eslint --fix .",
    "format": "npx prettier . --write",
    "test": "mocha --require test/hooks.js --recursive --parallel --timeout 10000 --exit",
    "cov": "c8 --reporter=lcov --reporter=html --reporter=text --report-dir ./docs/static/coverage mocha --require test/hooks.js --recursive --parallel --timeout 10000 --exit",
    "doc": "jsdoc -c .jsdoc.json",
    "preversion": "npm run cov && npm run lint && npm run format && npm run doc",
    "version": "git add -A docs/static/coverage docs/static/jsdoc",
    "postversion": "git push && git push --tags"
  },
  "author": "K-State ALT+CS Lab",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "express-xml-bodyparser": "github:macedigital/express-xml-bodyparser#v0.4.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "ky": "^2.0.2",
    "nanoid": "^5.1.11",
    "nunjucks": "^3.2.4",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "umzug": "^3.8.3",
    "winston": "^3.19.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-json-schema-ajv": "^5.2.4",
    "chai-shallow-deep-equal": "^1.4.6",
    "chai-string": "^2.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "oauth-sign": "^0.9.0",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  }
}
