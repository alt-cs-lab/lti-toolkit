<!DOCTYPE html>
<html lang="en">
  <head>
    <title>{{ title }}</title>
  </head>
  <body>
    <main>
        <h1>LTI Tool Provider</h1>
        {% if message %}
        <p style="color: green">{{ message }}
        {% endif %}
        {% if error %}
        <p style="color: red">{{ error }}
        {% endif %}
        <h2>{{ provider.name }}</h2>
        <h3>Settings</h3>
        <ul>
          <li><b>Launch URL:</b> {{ provider.launch_url }}</li>
          <li><b>Key:</b> {{ provider.key }}</li>
          <li><b>Secret:</b> {{ provider.maskedSecret }}
            <details>
              <summary>Reveal full secret</summary>
              {{ provider.secret }}
            </details>
          </li>
          <li><b>Custom: </b> {{ provider.custom }}</li>
          <li><b>LTI 1.3: </b> {{ provider.lti13 }}</li>
          <li><b>LTI 1.3 Client ID: </b> {{ provider.client_id }}</li>
          <li><b>LTI 1.3 Deployment ID: </b> {{ provider.deployment_id }}</li>
        </ul>
        <hr />
        <h3>Configure Launch</h3>
        <p>Provide information to configure an LTI Launch Request</p>
        <form method="POST" target="_blank" action="/provider/{{ provider.id }}/launch">
          <h4>Context (Course)</h4>
          <label for="context_key">Context Key</label><br>
          <input type="text" id="context_key" name="context_key" value="contextkey" size="50">
          <br>
          <label for="context_label">Context Label</label><br>
          <input type="text" id="context_label" name="context_label" value="LTI 101" size="50">
          <br>
          <label for="context_name">Context Name</label><br>
          <input type="text" id="context_name" name="context_name" value="LTI Demo Course" size="50">
          <br>
          <h4>Resource (Assignment)</h4>
          <label for="resource_key">Resource Key</label><br>
          <input type="text" id="resource_key" name="resource_key" value="resourcekey" size="50">
          <br>
          <label for="resource_name">Resource Name</label><br>
          <input type="text" id="resource_label" name="resource_name" value="LTI Demo Resource" size="50">
          <br>
          <h4>User</h4>
          <label for="user_key">User Key</label><br>
          <input type="text" id="user_key" name="user_key" value="userkey" size="50">
          <br>
          <label for="user_email">User Email</label><br>
          <input type="email" id="user_email" name="user_email" value="user@domain.tld" size="50">
          <br>
          <label for="user_given_name">User Given Name</label><br>
          <input type="text" id="user_given_name" name="user_given_name" value="GivenName" size="50">
          <br>
          <label for="user_family_name">User Family Name</label><br>
          <input type="text" id="user_family_name" name="user_family_name" value="FamilyName" size="50">
          <br>
          <h4>Launch Type</h4>
          <label for="manager">Instructor?</label>
          <input type="checkbox" id="manager" name="manager" value="true">
          <h4>Gradebook</h4>
          <label for="gradebook_id">Gradebook Key</label><br>
          <input type="text" id="gradebook_id" name="gradebook_id" value="gradebookkey" size="50">
          <h4>Custom</h4>
          <label for="custom">LTI Custom Values as a JSON object (e.g. {"key1": "value1", "key2": "value2"})</label><br>
          <input type="text" id="custom" name="custom" size="50">
          <br><br>
            <input type="submit" value="Submit">
        </form>
        {% if provider.lti13 %}
        <hr />
        <h3>Deep Link Request (LTI 1.3)</h3>
        <p>Initiate an LTI 1.3 Deep Linking request to allow the provider to share content items.</p>
        <form method="POST" action="/provider/{{ provider.id }}/deeplink">
          <h4>Context (Course)</h4>
          <label for="dl_context_key">Context Key</label><br>
          <input type="text" id="dl_context_key" name="context_key" value="contextkey" size="50">
          <br>
          <label for="dl_context_label">Context Label</label><br>
          <input type="text" id="dl_context_label" name="context_label" value="LTI 101" size="50">
          <br>
          <label for="dl_context_name">Context Name</label><br>
          <input type="text" id="dl_context_name" name="context_name" value="LTI Demo Course" size="50">
          <br>
          <h4>User</h4>
          <label for="dl_user_key">User Key</label><br>
          <input type="text" id="dl_user_key" name="user_key" value="userkey" size="50">
          <br>
          <label for="dl_user_email">User Email</label><br>
          <input type="email" id="dl_user_email" name="user_email" value="user@domain.tld" size="50">
          <br><br>
          <input type="submit" value="Launch Deep Link">
        </form>
        {% endif %}
        <hr />
        <h3>Edit Provider</h3>
        <form method="POST" action="/provider/{{ provider.id }}/update">
          <label for="edit_name">Provider Name</label><br>
          <input type="text" id="edit_name" name="name" value="{{ provider.name }}" size="50">
          <br>
          <label for="edit_launch_url">Launch URL</label><br>
          <input type="url" id="edit_launch_url" name="launch_url" value="{{ provider.launch_url }}" size="50">
          <br>
          <label for="edit_domain">Domain</label><br>
          <input type="text" id="edit_domain" name="domain" value="{{ provider.domain }}" size="50">
          <br>
          <label for="edit_custom">Custom Values (JSON object)</label><br>
          <input type="text" id="edit_custom" name="custom" value="{{ provider.custom }}" size="50">
          <br><br>
          <input type="submit" value="Save Changes">
        </form>
        <hr />
        <h3>Rotate Secret / Key Pair</h3>
        <p>Generates a new random secret (LTI 1.0) and RSA key pair (LTI 1.3). The old credentials will no longer work.</p>
        <form method="POST" action="/provider/{{ provider.id }}/rotate">
          <input type="submit" value="Rotate Credentials">
        </form>
        <hr />
        <h3>Delete Provider</h3>
        <p>Permanently removes this provider and all associated keys. This cannot be undone.</p>
        <form method="POST" action="/provider/{{ provider.id }}/delete">
          <input type="submit" value="Delete Provider" onclick="return confirm('Are you sure you want to delete this provider?')">
        </form>
        <hr />
        <details>
          <summary>LTI Debugging Information</summary>
          <p><b>LTI Provider</b></p>
          <pre>
{{ provider | dump(2) | safe }}
          </pre>
        </details>
    </main>
  </body>
</html>