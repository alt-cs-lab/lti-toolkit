<!DOCTYPE html>
<html lang="en">
  <head>
    <title>{{ title }}</title>
  </head>
  <body>
    <main>
        <h1>LTI Toolkit Example - Instructor View</h1>
        {% if message %}
        <p style="color: green">{{ message }}
        {% endif %}
        {% if error %}
        <p style="color: red">{{ error }}
        {% endif %}
        <p><b>Logged in as: </b>{{ launchData.user_name | d("Anonymous Instructor", true) }} &lt;{{ launchData.user_email | d("no email", true) }}&gt;</p>
        {% if launchData.launch_type == "lti1.3" %}
          <h2>LTI 1.3 Assignment and Grade Services (AGS)</h2>
          {% if agsError %}
            <p style="color: red">{{ agsError }}</p>
          {% else %}
            {% if lineItem %}
              <h3>Line Item Info</h3>
              <ul>
                <li><b>Label: </b> {{ lineItem.label }}</li>
                <li><b>Score Maximum: </b> {{ lineItem.scoreMaximum }}</li>
              </ul>
            {% endif %}
            {% if results %}
              <h3>Current Results</h3>
              {% if results.length == 0 %}
                <p>No results on file.</p>
              {% else %}
                <table border="1" cellpadding="4">
                  <tr>
                    <th>User ID</th>
                    <th>Score</th>
                    <th>Max Score</th>
                    <th>Comment</th>
                  </tr>
                  {% for result in results %}
                    <tr>
                      <td>{{ result.userId }}</td>
                      <td>{{ result.resultScore }}</td>
                      <td>{{ result.resultMaximum }}</td>
                      <td>{{ result.comment | d("—", true) }}</td>
                    </tr>
                  {% endfor %}
                </table>
              {% endif %}
            {% endif %}
          {% endif %}
        {% endif %}
        {% for courseId, course in courses %}
          <h2>{{ course.name }} ({{ course.label }})</h2>
          <p>
            <ul>
              <li><b>ID: </b> {{ courseId }}</li>
            </ul>
          </p>
          {% for assignmentId, assignment in course.assignments %}
            <h3>{{ assignment.name }}</h3>
            <p>
              <ul>
                <li><b>ID: </b> {{ assignmentId }}</li>
                <li><b>LTI 1.3 ID: </b> {{ assignment.lti_id }}</li>
                <li><b>Passback URL: </b> {{ assignment.grade_url }}</li>
              </ul>
            </p>
            {% for userId, grade in assignment.grades %}
              <h4>{{ grade.name | d("Anonymous Student", true) }} &lt;{{ grade.email | d("no email", true) }}&gt;</h4>
              <p>
                <ul>
                  <li><b>ID: </b> {{ userId }}</li>
                  <li><b>LTI 1.3 ID: </b> {{ grade.lis13_id }}</li>
                  <li><b>Outcome ID: </b> {{ grade.outcome_id }}</li>
                  <li><b>Current Score: </b>{{ grade.score }}</li>
                  <li>
                    <form method="POST" action="/instructor/grade">
                      <label for="grade"><b>Update Grade: </b></label>
                      <input type="number" id="grade" name="grade" min="0" max="1" step="0.01">
                      {% if launchData.launch_type == "lti1.3" %}
                      <br>
                      <label for="activityProgress"><b>Activity Progress: </b></label>
                      <select id="activityProgress" name="activityProgress">
                        <option value="Submitted" selected>Submitted</option>
                        <option value="Initialized">Initialized</option>
                        <option value="Started">Started</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Completed">Completed</option>
                      </select>
                      <br>
                      <label for="gradingProgress"><b>Grading Progress: </b></label>
                      <select id="gradingProgress" name="gradingProgress">
                        <option value="FullyGraded" selected>Fully Graded</option>
                        <option value="Pending">Pending</option>
                        <option value="PendingManual">Pending Manual</option>
                        <option value="Failed">Failed</option>
                        <option value="NotReady">Not Ready</option>
                      </select>
                      <br>
                      {% endif %}
                      <input type="hidden" id="course" name="course" value="{{ courseId }}">
                      <input type="hidden" id="assignment" name="assignment" value="{{ assignmentId }}">
                      <input type="hidden" id="user" name="user" value="{{ userId }}">
                      <input type="submit" value="Submit">
                    </form>
                  </li>
                  {% if launchData.launch_type == "lti1.0" and grade.outcome_id %}
                  <li>
                    <form method="POST" action="/instructor/read-grade">
                      <input type="hidden" name="course" value="{{ courseId }}">
                      <input type="hidden" name="assignment" value="{{ assignmentId }}">
                      <input type="hidden" name="user" value="{{ userId }}">
                      <input type="submit" value="Read Grade from LMS">
                    </form>
                  </li>
                  <li>
                    <form method="POST" action="/instructor/delete-grade">
                      <input type="hidden" name="course" value="{{ courseId }}">
                      <input type="hidden" name="assignment" value="{{ assignmentId }}">
                      <input type="hidden" name="user" value="{{ userId }}">
                      <input type="submit" value="Delete Grade from LMS">
                    </form>
                  </li>
                  {% endif %}
                </ul>
              </p>
            {% else %}
              <p>No students found!</p>
            {% endfor %}
          {% else %}
            <p>No assignments found!</p>
          {% endfor %}
        {% else %}
          <p>No courses found!</p>
        {% endfor %}
        <hr />
        <details>
          <summary>LTI Debugging Information</summary>
          <p><b>LTI Launch Data</b></p>
          <pre>
{{ launchData | dump(2) | safe }}
          </pre>
          <p><b>LTI Consumer</b></p>
          <pre>
{{ consumer | dump(2) | safe }}
          </pre>
        </details>
    </main>
  </body>
</html>
